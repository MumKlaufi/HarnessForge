<Window x:Class="HarnessForge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HarnessForge Explorer"
        Width="1100"
        Height="700"
        MinWidth="850"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Menu -->
		<Menu Grid.Row="0">
			<MenuItem Header="_File">
				<MenuItem Header="_New Project"/>
				<MenuItem Header="_Open"/>
				<Separator/>
				<MenuItem Header="E_xit"
                          Click="ExitMenuItem_Click"/>
			</MenuItem>

			<MenuItem Header="_Library"/>
			<MenuItem Header="_Tools"/>
			<MenuItem Header="_Help"/>
		</Menu>

		<!-- Toolbar -->
		<Border Grid.Row="1"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,0,1"
                Padding="10">

			<StackPanel Orientation="Horizontal">
				<Button Content="New Project"
                        Width="110"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="NewProjectButton_Click"/>

				<Button Content="Add Device"
                        Width="100"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="AddDeviceButton_Click"/>

				<Button Content="Validate"
                        Width="90"
                        Height="32"
                        Click="ValidateButton_Click"/>
			</StackPanel>
		</Border>

		<!-- Main workspace -->
		<Grid Grid.Row="2" Margin="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="300"/>
				<ColumnDefinition Width="8"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- Explorer -->
			<Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="4">

				<DockPanel>
					<Border DockPanel.Dock="Top"
                            Background="#E5E7EB"
                            Padding="12">

						<TextBlock Text="Engineering Explorer"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
					</Border>

					<TreeView x:Name="EngineeringTree"
                              Margin="8"
                              SelectedItemChanged="EngineeringTree_SelectedItemChanged">

						<TreeViewItem Header="Library"
                                      Tag="Library"
                                      IsExpanded="True">

							<TreeViewItem Header="Manufacturers"
                                          Tag="Manufacturers"
                                          IsExpanded="True">

								<TreeViewItem Header="MaxxECU"
                                              Tag="Manufacturer"
                                              IsExpanded="True">

									<TreeViewItem Header="Devices"
                                                  Tag="Devices"
                                                  IsExpanded="True">

										<TreeViewItem Header="MaxxECU Race"
                                                      Tag="MaxxECURace"/>

										<TreeViewItem Header="MaxxECU Pro"
                                                      Tag="MaxxECUPro"/>

										<TreeViewItem Header="MaxxECU Mini"
                                                      Tag="MaxxECUMini"/>
									</TreeViewItem>

									<TreeViewItem Header="Connectors"
                                                  Tag="Connectors"
                                                  IsExpanded="True">

										<TreeViewItem Header="Connector A"
                                                      Tag="ConnectorA"/>

										<TreeViewItem Header="Connector B"
                                                      Tag="ConnectorB"/>

										<TreeViewItem Header="Connector C"
                                                      Tag="ConnectorC"/>

										<TreeViewItem Header="Connector D"
                                                      Tag="ConnectorD"/>
									</TreeViewItem>

									<TreeViewItem Header="Contacts"
                                                  Tag="Contacts"/>

									<TreeViewItem Header="Seals"
                                                  Tag="Seals"/>
								</TreeViewItem>
							</TreeViewItem>
						</TreeViewItem>

						<TreeViewItem Header="Projects"
                                      Tag="Projects"
                                      IsExpanded="True">

							<TreeViewItem Header="Test Project"
                                          Tag="TestProject"
                                          IsExpanded="True">

								<TreeViewItem Header="Devices"
                                              Tag="ProjectDevices"/>

								<TreeViewItem Header="Wires"
                                              Tag="ProjectWires"/>

								<TreeViewItem Header="Validation"
                                              Tag="ProjectValidation"/>
							</TreeViewItem>
						</TreeViewItem>
					</TreeView>
				</DockPanel>
			</Border>

			<GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"/>

			<!-- Details -->
			<Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="4">

				<DockPanel>
					<Border DockPanel.Dock="Top"
                            Background="#E5E7EB"
                            Padding="12">

						<TextBlock Text="Details"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
					</Border>

					<ScrollViewer VerticalScrollBarVisibility="Auto">
						<StackPanel Margin="24">

							<TextBlock x:Name="DetailsTitle"
                                       Text="HarnessForge Explorer"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>

							<TextBlock x:Name="DetailsSubtitle"
                                       Text="Select an item from the engineering tree."
                                       Foreground="#6B7280"
                                       FontSize="14"
                                       Margin="0,0,0,24"/>

							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="160"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>

								<Grid.RowDefinitions>
									<RowDefinition Height="36"/>
									<RowDefinition Height="36"/>
									<RowDefinition Height="36"/>
									<RowDefinition Height="36"/>
									<RowDefinition Height="36"/>
								</Grid.RowDefinitions>

								<TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Type:"
                                           FontWeight="SemiBold"/>

								<TextBlock x:Name="TypeValue"
                                           Grid.Row="0"
                                           Grid.Column="1"
                                           Text="-"/>

								<TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="Manufacturer:"
                                           FontWeight="SemiBold"/>

								<TextBlock x:Name="ManufacturerValue"
                                           Grid.Row="1"
                                           Grid.Column="1"
                                           Text="-"/>

								<TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="Connectors:"
                                           FontWeight="SemiBold"/>

								<TextBlock x:Name="ConnectorsValue"
                                           Grid.Row="2"
                                           Grid.Column="1"
                                           Text="-"/>

								<TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Text="Pins:"
                                           FontWeight="SemiBold"/>

								<TextBlock x:Name="PinsValue"
                                           Grid.Row="3"
                                           Grid.Column="1"
                                           Text="-"/>

								<TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Text="Status:"
                                           FontWeight="SemiBold"/>

								<TextBlock x:Name="StatusValue"
                                           Grid.Row="4"
                                           Grid.Column="1"
                                           Text="-"/>
							</Grid>

							<Border Margin="0,24,0,0"
                                    Padding="14"
                                    Background="#F9FAFB"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="4">

								<TextBlock x:Name="DescriptionValue"
                                           TextWrapping="Wrap"
                                           Foreground="#4B5563"
                                           Text="This is the first interactive HarnessForge prototype."/>
							</Border>
						</StackPanel>
					</ScrollViewer>
				</DockPanel>
			</Border>
		</Grid>

		<!-- Status -->
		<StatusBar Grid.Row="3">
			<StatusBarItem>
				<TextBlock x:Name="StatusText"
                           Text="Ready"/>
			</StatusBarItem>

			<Separator/>

			<StatusBarItem>
				<TextBlock Text="Sample library loaded"/>
			</StatusBarItem>
		</StatusBar>
	</Grid>
</Window>