<Window x:Class="HarnessForge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HarnessForge Explorer"
        Width="1100"
        Height="700"
        MinWidth="850"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project"/>
                <MenuItem Header="_Open"/>
                <Separator/>
                <MenuItem Header="E_xit"/>
            </MenuItem>

            <MenuItem Header="_Library"/>
            <MenuItem Header="_Tools"/>
            <MenuItem Header="_Help"/>
        </Menu>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,0,1"
                Padding="10">

            <StackPanel Orientation="Horizontal">
                <Button Content="New Project"
                        Width="110"
                        Height="32"
                        Margin="0,0,8,0"/>

                <Button Content="Add Device"
                        Width="100"
                        Height="32"
                        Margin="0,0,8,0"/>

                <Button Content="Validate"
                        Width="90"
                        Height="32"/>
            </StackPanel>
        </Border>

        <!-- Main workspace -->
        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Explorer tree -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="4">

                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="#E5E7EB"
                            Padding="12">
                        <TextBlock Text="Engineering Explorer"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <TreeView Margin="8">
                        <TreeViewItem Header="Library" IsExpanded="True">
                            <TreeViewItem Header="Manufacturers" IsExpanded="True">
                                <TreeViewItem Header="MaxxECU" IsExpanded="True">
                                    <TreeViewItem Header="Devices" IsExpanded="True">
                                        <TreeViewItem Header="MaxxECU Race"/>
                                        <TreeViewItem Header="MaxxECU Pro"/>
                                        <TreeViewItem Header="MaxxECU Mini"/>
                                    </TreeViewItem>

                                    <TreeViewItem Header="Connectors"/>
                                    <TreeViewItem Header="Contacts"/>
                                    <TreeViewItem Header="Seals"/>
                                </TreeViewItem>
                            </TreeViewItem>
                        </TreeViewItem>

                        <TreeViewItem Header="Projects" IsExpanded="True">
                            <TreeViewItem Header="Test Project"/>
                        </TreeViewItem>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- Details panel -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="4">

                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="#E5E7EB"
                            Padding="12">
                        <TextBlock Text="Details"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <StackPanel Margin="24">
                        <TextBlock Text="MaxxECU Race"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="Engine Control Unit"
                                   Foreground="#6B7280"
                                   FontSize="14"
                                   Margin="0,0,0,24"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Manufacturer:"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="MaxxECU"/>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Device type:"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="ECU"/>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Connectors:"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="4"/>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Text="Pins:"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Text="124"/>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Text="Library status:"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Text="Sample data"/>
                        </Grid>

                        <Border Margin="0,24,0,0"
                                Padding="14"
                                Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="4">

                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#4B5563"
                                       Text="This is the first HarnessForge Explorer prototype. The information is currently sample data and the controls do not perform actions yet."/>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="Ready"/>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem>
                <TextBlock Text="Sample library loaded"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>